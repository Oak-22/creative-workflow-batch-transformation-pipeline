#!/usr/bin/env python3

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path


def parse_prompts(markdown: str) -> list[dict[str, str]]:
    prompts: list[dict[str, str]] = []
    sections = re.split(r"^##\s+", markdown, flags=re.MULTILINE)

    for section in sections[1:]:
        lines = section.splitlines()
        if not lines:
            continue

        title = lines[0].strip()
        body = "\n".join(lines[1:])

        shortcut_match = re.search(r"^Shortcut:\s*`([^`]+)`", body, flags=re.MULTILINE)
        code_match = re.search(r"```text\n(.*?)\n```", body, flags=re.DOTALL)

        if not code_match:
            continue

        prompts.append(
            {
                "title": title,
                "shortcut": shortcut_match.group(1).strip() if shortcut_match else "",
                "prompt": code_match.group(1).rstrip(),
            }
        )

    return prompts


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Print or copy a named agent prompt from agent_prompts.md"
    )
    parser.add_argument("query", nargs="?", help="Prompt title or shortcut")
    parser.add_argument("--copy", action="store_true", help="Copy the prompt to clipboard")
    parser.add_argument("--list", action="store_true", help="List available prompts")
    args = parser.parse_args()

    repo_root = Path(__file__).resolve().parent.parent
    prompt_file = repo_root / ".github" / "agent_instructions" / "global" / "agent_prompts.md"

    if not prompt_file.exists():
        print(f"Prompt file not found: {prompt_file}", file=sys.stderr)
        return 1

    prompts = parse_prompts(prompt_file.read_text())

    if args.list:
        for prompt in prompts:
            shortcut = f" ({prompt['shortcut']})" if prompt["shortcut"] else ""
            print(f"- {prompt['title']}{shortcut}")
        return 0

    if not args.query:
        parser.error("query is required unless --list is used")

    query = args.query.strip().lower()
    selected = next(
        (
            prompt
            for prompt in prompts
            if prompt["title"].strip().lower() == query
            or prompt["shortcut"].strip().lower() == query
        ),
        None,
    )

    if selected is None:
        print(f"No prompt found for: {args.query}", file=sys.stderr)
        print("Use --list to see available prompts.", file=sys.stderr)
        return 1

    prompt_text = selected["prompt"] + "\n"

    if args.copy:
        if shutil.which("pbcopy") is None:
            print("pbcopy is not available on this system.", file=sys.stderr)
            return 1
        subprocess.run(["pbcopy"], input=prompt_text, text=True, check=True)
        print(f'Copied prompt "{selected["title"]}" to clipboard.', file=sys.stderr)

    sys.stdout.write(prompt_text)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
